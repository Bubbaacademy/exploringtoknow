{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV", "DATABASE_URL", "PAYLOAD_SECRET", "PAYLOAD_PUBLIC_SERVER_URL",
    "S3_BUCKET", "S3_REGION", "S3_ACCESS_KEY_ID", "S3_SECRET_ACCESS_KEY",
    "ANTHROPIC_API_KEY", "OPENAI_API_KEY",
    "META_APP_ID", "META_APP_SECRET", "META_PAGE_ID", "META_IG_USER_ID", "META_LONG_LIVED_TOKEN",
    "GA4_PROPERTY_ID", "GSC_SITE_URL", "GOOGLE_APPLICATION_CREDENTIALS",
    "AMAZON_ATTRIBUTION_PROFILE_ID", "HUBSPOT_ACCESS_TOKEN",
    "AUTH_SECRET", "WORKER_CRON_DAILY",
    "PAYLOAD_INTERNAL_URL", "WORKER_PAYLOAD_API_KEY"
  ],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "dist/**", "!.next/cache/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": {},
    "typecheck": { "dependsOn": ["^build"] },
    "clean": { "cache": false }
  }
}
