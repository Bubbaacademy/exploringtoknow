# ExploringToKnow — PRODUCTION env template. Copy to /opt/exploringtoknow/env/.env
# 30-postgres.sh auto-generates the secrets/password on first run if left as CHANGE_ME.
NODE_ENV=production
DOMAIN=exploringtoknow.com

# --- Postgres (container) ---
POSTGRES_USER=etk
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=exploringtoknow
# app connects over the compose network to host 'postgres'
DATABASE_URL=postgres://etk:CHANGE_ME@postgres:5432/exploringtoknow

# --- Payload / auth ---
PAYLOAD_SECRET=CHANGE_ME
PAYLOAD_PUBLIC_SERVER_URL=https://exploringtoknow.com
AUTH_SECRET=CHANGE_ME

# --- AI (added when app deploy phase begins) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- S3 / others added in later phases ---
