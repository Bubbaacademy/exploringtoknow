# =============================================================================
# ExploringToKnow — Environment Variables (Phase 0 contract)
# Copy to .env and fill in. NEVER commit .env. All secrets via a real secret
# manager in production. Vars below are the full contract; later phases consume
# them — Phase 0 only requires DATABASE_URL, PAYLOAD_SECRET, AUTH_SECRET.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development

# ---- Database (PostgreSQL) — REQUIRED in Phase 0 ----------------------------
DATABASE_URL=postgres://etk:etk@localhost:5432/exploringtoknow

# ---- Payload CMS — REQUIRED in Phase 0 --------------------------------------
PAYLOAD_SECRET=change-me-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ---- Internal dashboard auth — REQUIRED in Phase 0 --------------------------
AUTH_SECRET=change-me-another-long-random-string

# ---- AWS S3 (media/storage) — Phase 1+ --------------------------------------
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- AI providers — Phase 1+ (LangGraph nodes) ------------------------------
# ANTHROPIC_API_KEY powers TEXT generation (articles/CTA/affiliate copy).
# OPENAI_API_KEY is OPTIONAL and used ONLY as a text-completion fallback. Image
# generation is DISABLED (manual-only image mode): the app NEVER calls any image
# generation/analysis API, so it runs whether or not OPENAI_API_KEY is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Meta Graph API (Facebook + Instagram ONLY) — Phase 2+ ------------------
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_IG_USER_ID=
META_LONG_LIVED_TOKEN=

# ---- Analytics sources — Phase 3+ -------------------------------------------
GA4_PROPERTY_ID=
GSC_SITE_URL=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
AMAZON_ATTRIBUTION_PROFILE_ID=
HUBSPOT_ACCESS_TOKEN=

# ---- Worker runtime ---------------------------------------------------------
# pg-boss reuses DATABASE_URL (no Redis required in Phase 0).
WORKER_CRON_DAILY=0 6 * * *

# Worker → Payload REST persistence (Approach B). The worker writes generation
# output (intelligence/brief/article + generation-runs) to the app over the
# compose network using a Payload user API key.
#   PAYLOAD_INTERNAL_URL  : in-cluster app URL (compose service name), e.g. http://app:3000
#   WORKER_PAYLOAD_API_KEY: API key of a dedicated operator user (enableAPIKey=true)
PAYLOAD_INTERNAL_URL=http://app:3000
WORKER_PAYLOAD_API_KEY=

# --- Newsletter / transactional email (Phase 6+; optional, local-safe when unset) ---
# Leave blank to run in local-safe mode (subscribers/contacts captured, no email sent).
NEWSLETTER_PROVIDER=
RESEND_API_KEY=
NEWSLETTER_FROM=
NEWSLETTER_REPLY_TO=
NEWSLETTER_DOUBLE_OPT_IN=
CONTACT_NOTIFY_TO=

# ---- Billing / Stripe (Phase 19) — local-safe placeholders ------------------
# When BILLING_ENABLED=true AND STRIPE_SECRET_KEY is set, online checkout/portal
# activate. Left empty = local-safe (no charges; "billing not active" responses).
# NEVER commit real values; production secrets live in the secret manager only.
BILLING_PROVIDER=local
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
STRIPE_BILLING_PORTAL_RETURN_URL=

# ---- Public signup / trial (Phase 15) --------------------------------------
PUBLIC_SIGNUP_ENABLED=false
FREE_TRIAL_DAYS=14
DEFAULT_WORKSPACE_PLAN=trial
REQUIRE_EMAIL_VERIFICATION=false

# ---- Provider connections / OAuth vault (Phase 30) — NAMES ONLY, no real values ----
# All EMPTY = local-safe: provider connections show "Not configured", no tokens stored,
# no provider API calls. NEVER commit real values; production secrets live in the secret
# manager only. PROVIDER_TOKEN_ENCRYPTION_KEY = 32 bytes as 64 hex chars OR base64; if
# missing/invalid the token vault is disabled and no token is ever stored.
PROVIDER_TOKEN_ENCRYPTION_KEY=

# Google Ads (first planned read-sync provider — Phase 31)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta Ads (Phase 32)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# TikTok Ads (later)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# LinkedIn Ads (later)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Pinterest Ads (later)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=
